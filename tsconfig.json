{
  "compilerOptions": {
      "lib": ["es2023"],
      "removeComments": true,
      "moduleResolution": "Node16",
      "module": "Node16",
      "noUnusedLocals": false,
      "noUnusedParameters": false,
      "sourceMap": true,
      "skipLibCheck": false,
      "esModuleInterop": true,
      "target": "ES2022",
      "outDir": "lib",
      "baseUrl": "./",
      "paths": {
          "~/*": ["./*"],
          "@/*": ["src/*"]
      }
  },
  "include": ["./**/*.ts"],
  "exclude": [
      "node_modules",
      ".serverless/**/*",
      ".webpack/**/*",
      ".warmup/**/*",
      ".vscode/**/*"
  ]
}
